# ── App ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://ptebtuning.com

# ── Email (Resend) ──────────────────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# Admin email that receives booking notifications
ADMIN_EMAIL=prestigeteamhelp@gmail.com

# ── Booking Calendar (Cal.com) ──────────────────────────────────────────
# Get your API key from: https://cal.com/settings/developer/api-keys
CALCOM_API_KEY=cal_your_calcom_api_key_here
CALCOM_API_URL=https://api.cal.com/v2

# ── SEO ─────────────────────────────────────────────────────────────────
# Get verification code from: https://search.google.com/search-console
GOOGLE_SITE_VERIFICATION=your_google_site_verification_code_here

# ── Shopify (hoodie checkout) ────────────────────────────────────────────────
# Get these from: Shopify Admin → Apps → Storefront API
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token_here

# The handle of the hoodie product in Shopify (from product URL)
SHOPIFY_HOODIE_HANDLE=tuned-by-pteb-hoodie
