# ─────────────────────────────────────────────────────────────────────────────
# PTEB TUNING — Environment Variables Setup Guide
#
# FOR NETLIFY DEPLOYMENT:
#   Netlify dashboard → your site → Site configuration → Environment variables
#   Add each variable below with its real value, then trigger a redeploy.
#
# FOR LOCAL DEVELOPMENT:
#   Copy this file → rename to .env.local → fill in real values → restart server
# ─────────────────────────────────────────────────────────────────────────────


# ── SHOPIFY ───────────────────────────────────────────────────────────────────
# Enables the "Add to Cart" buy buttons for the Warport ($499) and Hoodie.
# Without these, the buttons show a WhatsApp fallback instead of a real cart.
#
# How to get your Storefront Access Token:
#   1. Shopify Admin → Settings → Apps and sales channels → Develop apps
#   2. Create app → name it "PTEB Website" → Configure Storefront API
#   3. Enable scopes: unauthenticated_read_product_listings + unauthenticated_write_checkouts
#   4. Install app → copy the "Storefront API access token"
#
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token

# These must match your Shopify product URL slugs exactly
SHOPIFY_WARPORT_HANDLE=pteb-warport
SHOPIFY_HOODIE_HANDLE=tuned-by-pteb-hoodie


# ── RESEND (Email — contact forms & enquiries) ────────────────────────────────
# Makes the contact page and Warport enquiry form send emails to ADMIN_EMAIL.
# Without this, form submissions are silently lost.
#
# How to get your API key:
#   1. Go to resend.com → sign up (free plan works)
#   2. API Keys → Create API key → copy it here
#
# How to send from your own domain (noreply@ptebtuning.com):
#   1. Resend dashboard → Domains → Add domain → type: ptebtuning.com
#   2. Add the DNS records Resend gives you (in your domain registrar / Cloudflare)
#   3. Once verified, set RESEND_FROM_EMAIL=noreply@ptebtuning.com
#
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@ptebtuning.com
ADMIN_EMAIL=prestigeteamhelp@gmail.com


# ── APP URL (do not change) ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://ptebtuning.com
